{
  "uniquekey": "employee-leave-request-flow",
  "name": "员工请假审批流程",
  "description": "根据请假天数自动选择审批路径：≤3天由部门经理审批，>3天由公司领导审批，审批通过后需综合管理部备案",
  "initNum": 7,
