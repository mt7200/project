## 数据映射文件(database)，创建于2026/7/20 15:35:00

-- ============================================================
-- 数据统计聚合查询
-- ============================================================

-- 门诊工作量统计
SELECT COUNT(*) AS visit_count,
       DATE(v.created_at) AS visit_date
FROM visit_record v
WHERE 1=1
<if test="startDate != null and startDate != ''">
    AND v.created_at >= #{startDate}
</if>
<if test="endDate != null and endDate != ''">
    AND v.created_at &lt;= #{endDate}
</if>
<if test="doctorId != null">
    AND v.doctor_id = #{doctorId}
</if>
GROUP BY DATE(v.created_at)
ORDER BY visit_date DESC

-- 证型分布统计
SELECT dr.pattern_code, dr.pattern_name, COUNT(*) AS count
FROM diagnosis_result dr
WHERE 1=1
<if test="startDate != null and startDate != ''">
    AND dr.created_at >= #{startDate}
</if>
<if test="endDate != null and endDate != ''">
    AND dr.created_at &lt;= #{endDate}
</if>
GROUP BY dr.pattern_code, dr.pattern_name
ORDER BY count DESC

-- 科室就诊排名
SELECT u.real_name AS doctor_name, u.dept_name, COUNT(*) AS visit_count
FROM visit_record v
LEFT JOIN sys_user u ON v.doctor_id = u.id
WHERE 1=1
<if test="startDate != null and startDate != ''">
    AND v.created_at >= #{startDate}
</if>
<if test="endDate != null and endDate != ''">
    AND v.created_at &lt;= #{endDate}
</if>
GROUP BY v.doctor_id, u.real_name, u.dept_name
ORDER BY visit_count DESC

-- 处方开具统计
SELECT COUNT(*) AS prescription_count,
       DATE(p.created_at) AS p_date
FROM prescription p
WHERE 1=1
<if test="startDate != null and startDate != ''">
    AND p.created_at >= #{startDate}
</if>
<if test="endDate != null and endDate != ''">
    AND p.created_at &lt;= #{endDate}
</if>
<if test="status != null and status != ''">
    AND p.status = #{status}
</if>
GROUP BY DATE(p.created_at)
ORDER BY p_date DESC

-- 常用方剂排名
SELECT f.id, f.name, COUNT(*) AS usage_count
FROM prescription p
LEFT JOIN formula f ON p.formula_id = f.id
WHERE 1=1
<if test="startDate != null and startDate != ''">
    AND p.created_at >= #{startDate}
</if>
<if test="endDate != null and endDate != ''">
    AND p.created_at &lt;= #{endDate}
</if>
GROUP BY f.id, f.name
ORDER BY usage_count DESC
LIMIT #{offset}, #{pageSize}

-- 用药频次统计
SELECT h.id, h.name, SUM(pi.quantity) AS total_quantity, COUNT(DISTINCT p.id) AS prescription_count
FROM prescription_item pi
LEFT JOIN prescription p ON pi.prescription_id = p.id
LEFT JOIN herb h ON pi.herb_id = h.id
WHERE 1=1
<if test="startDate != null and startDate != ''">
    AND p.created_at >= #{startDate}
</if>
<if test="endDate != null and endDate != ''">
    AND p.created_at &lt;= #{endDate}
</if>
GROUP BY h.id, h.name
ORDER BY total_quantity DESC
LIMIT #{offset}, #{pageSize}
